{
  "name": "@codebuff/cli-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "codebuff-lite": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run prebuild:agents && bun run src/index.ts --cwd ..",
    "typecheck": "tsc --noEmit -p .",
    "build:binary": "bun ./scripts/build-binary.ts codebuff-lite $npm_package_version",
    "prebuild:agents": "bun run scripts/prebuild-agents.ts"
  },
  "dependencies": {
    "@codebuff/sdk": "workspace:*",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5"
  }
}
